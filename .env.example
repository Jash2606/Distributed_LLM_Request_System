DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/llm_processor
REDIS_URL=redis://localhost:6379/0
WORKER_CONCURRENCY=4
SIMILARITY_THRESHOLD=0.9
MAX_JOB_ATTEMPTS=5
LEASE_SECONDS=15
HEARTBEAT_INTERVAL=5
REAPER_INTERVAL=5
API_TIMEOUT_SECONDS=10
LLM_PROVIDER=mock
EMBED_PROVIDER=mock
EMBED_DIM=384
LLM_FAILURE_RATE=0.05
LLM_LATENCY_MIN=0.2
LLM_LATENCY_MAX=0.5
RATE_LIMIT_CAPACITY=300
RATE_LIMIT_REFILL_PER_SEC=5.0
LOG_LEVEL=INFO
APP_NAME=llm-processor
