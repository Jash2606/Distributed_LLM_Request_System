          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/metrics",
              "host": ["{{base_url}}"],
              "path": ["metrics"]
            },
            "description": "Returns Prometheus text-format metrics for scraping.\n\nKey metrics exposed:\n- `prompt_requests_total{status, cached}` — request counters\n- `prompt_cache_hits_total{match_type}` — cache hit counters (exact | semantic)\n- `prompt_cache_misses_total` — cache miss counter\n- `llm_calls_total{outcome}` — LLM call outcomes (success | failure)\n- `rate_limit_denials_total` — rate-limited requests\n- `job_queue_depth` — current queue depth gauge\n- `worker_active_jobs{worker_id}` — active jobs per worker gauge\n- `processing_latency_seconds{stage}` — latency histograms (cache | llm | total)\n- `job_attempts_total` — retry histogram"
