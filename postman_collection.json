    {
      "name": "3 - Health & Monitoring",
      "description": "System health check and Prometheus metrics endpoints.",
      "item": [
        {
          "name": "Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "pm.test('Has status field', () => pm.expect(['healthy', 'degraded']).to.include(res.status));",
                  "pm.test('Has timestamp', () => pm.expect(res.timestamp).to.be.a('string'));",
                  "pm.test('Has components', () => pm.expect(res.components).to.be.an('object'));",
                  "pm.test('Database component present', () => pm.expect(res.components.database).to.be.a('string'));",
                  "pm.test('Worker component present', () => pm.expect(res.components.worker).to.be.a('string'));",
                  "pm.test('Cache component present', () => pm.expect(res.components.cache).to.be.a('string'));",
                  "",
                  "const allHealthy = res.status === 'healthy';",
                  "console.log('System status:', res.status);",
                  "console.log('Database:', res.components.database);",
                  "console.log('Worker:', res.components.worker);",
                  "console.log('Cache:', res.components.cache);",
                  "",
                  "if (!allHealthy) {",
                  "    console.warn('System is DEGRADED — check service logs');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Returns system health status including:\n- `database`: PostgreSQL connectivity (`connected` | `unavailable`)\n- `worker`: Worker liveness based on recent heartbeats (`running` | `idle` | `unknown`)\n- `cache`: Redis connectivity (`available` | `unavailable`)\n\nOverall status is `healthy` only when all three components report OK.\n\nUsed by Docker Compose healthchecks and can be wired to Kubernetes liveness/readiness probes."
          },
          "response": [
            {
              "name": "All Healthy",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {"raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"]}
