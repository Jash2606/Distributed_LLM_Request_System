              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n    \"status\": \"degraded\",\n    \"timestamp\": \"2025-05-28T10:30:00.000000+00:00\",\n    \"components\": {\n        \"database\": \"connected\",\n        \"worker\": \"idle\",\n        \"cache\": \"unavailable\"\n    }\n}"
            }
          ]
