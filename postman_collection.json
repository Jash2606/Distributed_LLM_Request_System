              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n    \"status\": \"healthy\",\n    \"timestamp\": \"2025-05-28T10:30:00.000000+00:00\",\n    \"components\": {\n        \"database\": \"connected\",\n        \"worker\": \"running\",\n        \"cache\": \"available\"\n    }\n}"
            },
            {
              "name": "Degraded (Redis down)",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {"raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"]}
